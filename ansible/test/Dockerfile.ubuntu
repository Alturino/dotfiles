FROM ubuntu:24.04

RUN apt update && apt install -y \
    locales \
    python3 \
    python3-pip \
    python3-venv \
    python3-apt \
    curl \
    git \
    unzip \
    zip \
    zsh \
    sudo \
    nodejs \
    npm

RUN pip3 install ansible --break-system-packages

RUN mkdir -p /etc/ansible && printf '[defaults]\ndeprecation_warnings=False\n' > /etc/ansible/ansible.cfg

RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

WORKDIR /ansible

COPY run-tests.sh /usr/local/bin/run-tests
RUN chmod +x /usr/local/bin/run-tests

USER testuser

CMD ["run-tests"]
