FROM fedora:41

RUN dnf install -y \
    python3 \
    python3-pip \
    python3-libdnf5 \
    glibc-langpack-en \
    curl \
    git \
    unzip \
    zip \
    zsh \
    sudo \
    nodejs \
    npm \
    && dnf clean all

RUN pip3 install ansible

RUN mkdir -p /etc/ansible && printf '[defaults]\ndeprecation_warnings=False\n' > /etc/ansible/ansible.cfg

RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

WORKDIR /ansible

COPY run-tests.sh /usr/local/bin/run-tests
RUN chmod +x /usr/local/bin/run-tests

USER testuser

CMD ["run-tests"]
