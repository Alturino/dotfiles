{
  "ifer": {
    "prefix": "ifer",
    "body": ["if err != nil {", "\t$0", "}"],
    "description": "if err != nil"
  },
  "fms": {
    "prefix": "fms",
    "body": ["fmt.Sprintf(\"$0\", $1)"],
    "description": "Sprintf"
  },
  "fme": {
    "prefix": "fme",
    "body": ["fmt.Errorf(\"$0 error:%w\", $1, err)"],
    "description": "Errorf"
  },
  "net/http middleware": {
    "prefix": "midf",
    "body": [
      "func ${1:name}() func(http.Handler) http.Handler {",
      "\treturn func(next http.Handler) http.Handler {",
      "\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {",
      "\t\t\t$0",
      "\t\t\tnext.ServeHTTP(w, r)",
      "\t\t})",
      "\t}",
      "}"
    ],
    "description": "net/http middleware"
  },
  "http HandlerFunc": {
    "prefix": "hf",
    "body": [
      "func ${1:name}() http.HandlerFunc {",
      "\treturn func(w http.ResponseWriter, r *http.Request) {",
      "\t\t$0",
      "}"
    ],
    "description": "HandlerFunc"
  },
  "controller HandlerFunc": {
    "prefix": "hfc",
    "body": [
      "func (c ${1:controller_name}) ${2:func_name}() http.HandlerFunc {",
      "\treturn func(w http.ResponseWriter, r *http.Request) {",
      "\t\t$0",
      "}"
    ],
    "description": "HandlerFunc"
  },
  "Zerolog Initialization": {
    "prefix": "zerologinit",
    "body": [
      "func Get(config ${1:config.Logger}) zerolog.Logger {",
      "\treturn initLog(config)()",
      "}",
      "",
      "func initLog(config ${1:config.Logger}) func() zerolog.Logger {",
      "\treturn sync.OnceValue(func() zerolog.Logger {",
      "\t\tzerolog.DurationFieldUnit = time.Microsecond",
      "\t\tzerolog.ErrorFieldName = \"e\"",
      "\t\tzerolog.ErrorStackFieldName = \"st\"",
      "\t\tzerolog.ErrorStackMarshaler = pkgerrors.MarshalStack",
      "\t\tzerolog.LevelFieldName = \"l\"",
      "\t\tzerolog.MessageFieldName = \"msg\"",
      "\t\tzerolog.TimestampFieldName = \"t\"",
      "",
      "\t\tlogLevel := zerolog.InfoLevel",
      "\t\tdir := filepath.Dir(\"${2:/var/log/}\")",
      "\t\tif config.Env == \"${3:development}\" {",
      "\t\t\tlogLevel = zerolog.TraceLevel",
      "\t\t\tdir = filepath.Dir(\".\")",
      "\t\t}",
      "",
      "\t\tfilename := filepath.Join(dir, config.Name+\".log\")",
      "\t\tfileWriter := &lumberjack.Logger{Filename: filename, Compress: true}",
      "\t\toutput := zerolog.MultiLevelWriter(os.Stdout, fileWriter)",
      "",
      "\t\t// Create the instance",
      "\t\tl := zerolog.New(output).",
      "\t\t\tLevel(logLevel).",
      "\t\t\tWith().",
      "\t\t\tTimestamp().",
      "\t\t\tCaller().",
      "\t\t\tStack().",
      "\t\t\tInt(\"pid\", os.Getpid()).",
      "\t\t\tInt(\"gid\", os.Getgid()).",
      "\t\t\tInt(\"uid\", os.Getuid()).",
      "\t\t\tLogger().",
      "\t\t\tHook(TraceHook(), BaggageHook())",
      "",
      "\tl.Info().",
      "\t\tStr(${4:constants.KEY_TAG}, \"logging Get\").",
      "\t\tStr(${5:constants.KEY_PROCESS}, \"initiating logging\").",
      "\t\tMsg(\"finish initiating logging\")",
      "",
      "\t\t// Update globals",
      "\t\tzerolog.DefaultContextLogger = &l",
      "\t\tlog.Logger = l",
      "",
      "\t\treturn l",
      "\t})",
      "}"
    ],
    "description": "Initialize zerolog with sync.OnceValue, file rotation, and custom hooks."
  },
  "Zerolog Trace Hook": {
    "prefix": "zerologtracehook",
    "body": [
      "func TraceHook() zerolog.HookFunc {",
      "\treturn func(e *zerolog.Event, level zerolog.Level, message string) {",
      "\t\tspanContext := trace.SpanContextFromContext(e.GetCtx())",
      "\t\tif spanContext.IsValid() {",
      "\t\t\te.Str(\"${1:trace_id}\", spanContext.TraceID().String()).",
      "\t\t\t\tStr(\"${2:span_id}\", spanContext.SpanID().String())",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "Zerolog hook to automatically extract and inject OpenTelemetry TraceID and SpanID from context."
  },
  "Zerolog Baggage Hook": {
    "prefix": "zerologbaghook",
    "body": [
      "func BaggageHook() zerolog.HookFunc {",
      "\treturn func(e *zerolog.Event, level zerolog.Level, message string) {",
      "\t\tbg := baggage.FromContext(e.GetCtx())",
      "\t\tfor _, member := range bg.Members() {",
      "\t\t\te.Str(member.Key(), member.Value())",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "Zerolog hook to extract OpenTelemetry baggage from context and add as log fields."
  },
  "Slog Multi Logger Initialization": {
    "prefix": "sloginit",
    "body": [
      "func ${1:Get}(config ${2:config.Config}) *slog.Logger {",
      "\treturn ${3:initLogger}(config)()",
      "}",
      "",
      "func ${3:initLogger}(config ${2:config.Config}) func() *slog.Logger {",
      "\treturn sync.OnceValue(func() *slog.Logger {",
      "\t\tlogfile := &lumberjack.Logger{",
      "\t\t\tFilename:  filepath.Join(config.LogDir, \"${4:app}.log\"),",
      "\t\t\tMaxSize:   1000, // megabytes",
      "\t\t\tMaxAge:    30,",
      "\t\t\tCompress:  true,",
      "\t\t\tLocalTime: true,",
      "\t\t}",
      "\t\tlogDestination := io.MultiWriter(os.Stdout, logfile)",
      "",
      "\t\tloglevel := slog.LevelInfo",
      "\t\tsinkHandlerOption := &slog.HandlerOptions{Level: loglevel, AddSource: true}",
      "\t\tvar sinkHandler slog.Handler = slog.NewJSONHandler(logDestination, sinkHandlerOption)",
      "\t\tif config.Env == \"development\" {",
      "\t\t\tloglevel = slog.LevelDebug",
      "\t\t}",
      "",
      "\t\tpipe := slogmulti.Pipe(",
      "\t\t\tslogmulti.NewHandleInlineMiddleware(",
      "\t\t\t\tfunc(ctx context.Context, record slog.Record, next func(context.Context, slog.Record) error) error {",
      "\t\t\t\t\tspan := trace.SpanContextFromContext(ctx)",
      "\t\t\t\t\tif span.IsValid() {",
      "\t\t\t\t\t\trecord.AddAttrs(",
      "\t\t\t\t\t\t\tslog.String(\"trace_id\", span.TraceID().String()),",
      "\t\t\t\t\t\t\tslog.String(\"span_id\", span.SpanID().String()),",
      "\t\t\t\t\t\t)",
      "\t\t\t\t\t}",
      "\t\t\t\t\treturn next(ctx, record)",
      "\t\t\t\t},",
      "\t\t\t),",
      "\t\t).Handler(sinkHandler).",
      "\t\t\tWithAttrs([]slog.Attr{slog.String(\"app\", \"${4:app}\")})",
      "",
      "\t\tlogger := slog.New(slogmulti.Fanout(pipe))",
      "\t\tslog.SetDefault(logger)",
      "",
      "\t\treturn logger",
      "\t})",
      "}"
    ],
    "description": "Initialize a multi-destination slog logger with OpenTelemetry middleware and log rotation."
  },
  "NATS Handlers & Init": {
    "prefix": "natsbootstrap",
    "body": [
      "func disconnectErrHandler(ctx context.Context) nats.ConnErrHandler {",
      "\tlogger := zerolog.Ctx(ctx).With().Ctx(ctx).Str(${1:constants.KEY_TAG}, \"nats disconnectErrHandler\").Logger()",
      "\treturn func(c *nats.Conn, err error) {",
      "\t\t_, span := tracer.Start(context.Background(), \"DisconnectErrHandler\")",
      "\t\tdefer span.End()",
      "",
      "\t\terr = fmt.Errorf(\"nats disconnected with error: %w\", err)",
      "\t\tlogger.Error().Err(err).Msg(err.Error())",
      "\t\totelutil.RecordError(err, span)",
      "\t}",
      "}",
      "",
      "func reconnectErrHandler(ctx context.Context) nats.ConnErrHandler {",
      "\tlogger := zerolog.Ctx(ctx).With().Ctx(ctx).Str(${1:constants.KEY_TAG}, \"nats reconnectErrHandler\").Logger()",
      "\treturn func(_ *nats.Conn, err error) {",
      "\t\t_, span := tracer.Start(context.Background(), \"ReconnectErrHandler\")",
      "\t\tdefer span.End()",
      "",
      "\t\terr = fmt.Errorf(\"nats failed to reconnect with err: %w\", err)",
      "\t\tlogger.Error().Err(err).Msg(err.Error())",
      "\t\totelutil.RecordError(err, span)",
      "\t}",
      "}",
      "",
      "func reconnectHandler(ctx context.Context) nats.ConnHandler {",
      "\tlogger := zerolog.Ctx(ctx).With().Ctx(ctx).Str(${1:constants.KEY_TAG}, \"nats reconnectHandler\").Logger()",
      "\treturn func(c *nats.Conn) {",
      "\t\t_, span := tracer.Start(context.Background(), \"ReconnectHandler\")",
      "\t\tdefer span.End()",
      "\t\tlogger.Debug().Msg(\"nats reconnected\")",
      "\t}",
      "}",
      "",
      "func closedHandler(ctx context.Context) nats.ConnHandler {",
      "\tlogger := zerolog.Ctx(ctx).With().Ctx(ctx).Str(${1:constants.KEY_TAG}, \"nats closedHandler\").Logger()",
      "\treturn func(c *nats.Conn) {",
      "\t\t_, span := tracer.Start(context.Background(), \"ClosedHandler\")",
      "\t\tdefer span.End()",
      "\t\tlogger.Debug().Msg(\"nats closed\")",
      "\t}",
      "}",
      "",
      "func discoverHandler(ctx context.Context) nats.ConnHandler {",
      "\tlogger := zerolog.Ctx(ctx).With().Ctx(ctx).Str(${1:constants.KEY_TAG}, \"nats discoverHandler\").Logger()",
      "\treturn func(c *nats.Conn) {",
      "\t\tlogger.Debug().",
      "\t\t\tStrs(\"known_nats_servers\", c.Servers()).",
      "\t\t\tStrs(\"discovered_nats_servers\", c.DiscoveredServers()).",
      "\t\t\tMsg(\"nats discovered new server\")",
      "\t}",
      "}",
      "",
      "func errHandler(ctx context.Context) nats.ErrHandler {",
      "\tlogger := zerolog.Ctx(ctx).With().Ctx(ctx).Str(${1:constants.KEY_TAG}, \"nats errHandler\").Logger()",
      "\treturn func(c *nats.Conn, s *nats.Subscription, err error) {",
      "\t\t_, span := tracer.Start(ctx, \"ErrHandler\")",
      "\t\tdefer span.End()",
      "\t\terr = fmt.Errorf(\"nats received err: %w\", err)",
      "\t\tlogger.Error().Err(err).Msg(err.Error())",
      "\t\totelutil.RecordError(err, span)",
      "\t}",
      "}",
      "",
      "func Get(ctx context.Context, config ${2:config.Nats}) (*nats.Conn, error) {",
      "\t_, span := tracer.Start(ctx, \"main Get\")",
      "\tdefer span.End()",
      "",
      "\treturn initNats(ctx, config)()",
      "}",
      "",
      "func initNats(ctx context.Context, config ${2:config.Nats}) func() (*nats.Conn, error) {",
      "\t_, span := otelutil.Tracer.Start(ctx, \"main initNats\")",
      "\tdefer span.End()",
      "",
      "\treturn sync.OnceValues(func() (*nats.Conn, error) {",
      "\t\tendpoint := fmt.Sprintf(\"%s:%d\", config.Host, config.Port)",
      "\t\tnatsConn, err := nats.Connect(",
      "\t\t\tendpoint,",
      "\t\t\tnats.DisconnectErrHandler(disconnectErrHandler(ctx)),",
      "\t\t\tnats.ReconnectErrHandler(reconnectErrHandler(ctx)),",
      "\t\t\tnats.ReconnectHandler(reconnectHandler(ctx)),",
      "\t\t\tnats.ClosedHandler(closedHandler(ctx)),",
      "\t\t\tnats.DiscoveredServersHandler(discoverHandler(ctx)),",
      "\t\t\tnats.ErrorHandler(errHandler(ctx)),",
      "\t\t)",
      "\t\tif err != nil {",
      "\t\t\terr = fmt.Errorf(\"failed connecting to nats with error: %w\", err)",
      "\t\t\treturn nil, err",
      "\t\t}",
      "\t\treturn natsConn, nil",
      "\t})",
      "}"
    ],
    "description": "Full NATS connection setup with observability (Tracing/Logging) and connection handlers."
  },
  "PGX Pool Initialization": {
    "prefix": "pgxinit",
    "body": [
      "func Get(ctx context.Context, config ${1:config.Database}) (*pgxpool.Pool, error) {",
      "\tctx, span := otelutil.Tracer.Start(ctx, \"main Get\")",
      "\tdefer span.End()",
      "",
      "\treturn initPgxPool(ctx, config)()",
      "}",
      "",
      "func initPgxPool(ctx context.Context, config ${1:config.Database}) func() (*pgxpool.Pool, error) {",
      "\tctx, span := otelutil.Tracer.Start(ctx, \"main initPgxPool\")",
      "\tdefer span.End()",
      "",
      "\treturn sync.OnceValues(func() (*pgxpool.Pool, error) {",
      "\t\tpostgresURL := postgresURL(config)",
      "\t\tpgxConfig, err := pgxpool.ParseConfig(postgresURL)",
      "\t\tif err != nil {",
      "\t\t\terr = fmt.Errorf(\"failed creating pgx config with error: %w\", err)",
      "\t\t\treturn nil, err",
      "\t\t}",
      "",
      "\t\tpgxConfig.AfterConnect = func(ctx context.Context, pgxConn *pgx.Conn) error {",
      "\t\t\tpgxUUID.Register(pgxConn.TypeMap())",
      "\t\t\treturn nil",
      "\t\t}",
      "\t\tpgxConfig.ConnConfig.Tracer = otelpgx.NewTracer(",
      "\t\t\totelpgx.WithTracerAttributes(semconv.DBSystemPostgreSQL),",
      "\t\t)",
      "\t\tpool, err := pgxpool.NewWithConfig(ctx, pgxConfig)",
      "\t\tif err != nil {",
      "\t\t\terr = fmt.Errorf(\"failed creating connection pool with error: %w\", err)",
      "\t\t\treturn nil, err",
      "\t\t}",
      "",
      "\t\terr = pool.Ping(ctx)",
      "\t\tif err != nil {",
      "\t\t\terr = fmt.Errorf(\"failed ping db with error: %w\", err)",
      "\t\t\treturn nil, err",
      "\t\t}",
      "",
      "\t\tif err = MigrateUp(ctx, config, pool, postgresURL); err != nil {",
      "\t\t\terr = fmt.Errorf(\"failed migration up with error: %w\", err)",
      "\t\t\treturn nil, err",
      "\t\t}",
      "\t\treturn pool, nil",
      "\t})",
      "}"
    ],
    "description": "Initialize pgxpool with sync.OnceValues, OTel tracing, UUID registration, and migrations."
  },
  "Minio Initialization": {
    "prefix": "minioinit",
    "body": [
      "func Get(ctx context.Context, config ${1:config.Minio}) (*minio.Client, error) {",
      "\treturn initMinio(ctx, config)()",
      "}",
      "",
      "func initMinio(ctx context.Context, config ${1:config.Minio}) func() (*minio.Client, error) {",
      "\treturn sync.OnceValues(func() (*minio.Client, error) {",
      "\t\tendpoint := fmt.Sprintf(\"%s:%d\", config.Host, config.Port)",
      "\t\tclient, err := minio.New(endpoint, &minio.Options{",
      "\t\t\tTrace: otelhttptrace.NewClientTrace(ctx, otelhttptrace.WithInsecureHeaders()),",
      "\t\t\tCreds: credentials.NewStaticV4(\"${2:minio}\", \"${3:minio_minio}\", \"\"),",
      "\t\t})",
      "\t\tif err != nil {",
      "\t\t\terr = fmt.Errorf(\"error creating minio client: %w\", err)",
      "\t\t\treturn nil, err",
      "\t\t}",
      "\t\treturn client, nil",
      "\t})",
      "}"
    ],
    "description": "Initialize MinIO client with sync.OnceValues and OTel HTTP tracing."
  },
  "OpenTelemetry Span": {
    "prefix": "ts",
    "body": [
      "ctx, ${1:span} := ${2:tracer}.Start(",
      "\tctx,",
      "\t\"${3:OperationName}\",",
      "\ttrace.WithSpanKind(trace.SpanKindClient),",
      "\ttrace.WithAttributes(attribute.String(\"${4:key}\", ${5:value})),",
      ")",
      "defer ${1:span}.End()",
      "$0"
    ],
    "description": "Create an OpenTelemetry span with defer end"
  },
  "Slog With": {
    "prefix": "slw",
    "body": ["${1:logger} := ${2:logger}.With(", "$0", ")"],
    "description": "Create a scoped slog logger with attributes"
  },
  "Slog Debug Context": {
    "prefix": "sldc",
    "body": ["${1:logger}.DebugContext(${2:ctx}, \"${3:message}\")$0"],
    "description": "slog debug message with context"
  },
  "Slog Info Context": {
    "prefix": "slic",
    "body": ["${1:logger}.InfoContext(${2:ctx}, \"${3:message}\")$0"],
    "description": "slog info message with context"
  },
  "Slog Error Context": {
    "prefix": "slec",
    "body": ["${1:logger}.ErrorContext(${2:ctx}, \"${3:message}\")$0"],
    "description": "slog error message with context"
  },
  "OTEL Span Event": {
    "prefix": "se",
    "body": ["${1:span}.AddEvent(\"${2:event name}\")$0"],
    "description": "Add an event to an OpenTelemetry span"
  }
}
